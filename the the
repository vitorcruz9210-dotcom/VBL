    local function CriarBotaoToggle(textoOff, textoOn, posY, rewardId)
        local btn = Instance.new("TextButton")
        btn.Parent = ContentFrame
        btn.BackgroundColor3 = CORES.FUNDO_BOTAO
        btn.BackgroundTransparency = 0.5
        btn.BorderSizePixel = 0
        btn.Position = UDim2.new(0, 15, 0, posY)
        btn.Size = UDim2.new(1, -30, 0, 32)
        btn.Font = Enum.Font.GothamBold
        btn.Text = textoOff
        btn.TextColor3 = CORES.TEXTO_BRANCO
        btn.TextSize = 13
        btn.AutoButtonColor = false

        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 8)
        btnCorner.Parent = btn

        local ativo = false

        local function atualizarVisual()
            if ativo then
                btn.Text = textoOn
                TweenService:Create(btn, TweenInfo.new(0.2), {
                    BackgroundColor3 = Color3.fromRGB(50, 200, 50),
                    BackgroundTransparency = 0.3
                }):Play()
            else
                btn.Text = textoOff
                TweenService:Create(btn, TweenInfo.new(0.2), {
                    BackgroundColor3 = CORES.FUNDO_BOTAO,
                    BackgroundTransparency = 0.5
                }):Play()
            end
        end

        local function executarRecompensa()
            if not remote then
                remote = ReplicatedStorage:WaitForChild("Packages"):WaitForChild("_Index")
                    :WaitForChild("sleitnick_knit@1.7.0"):WaitForChild("knit")
                    :WaitForChild("Services"):WaitForChild("SeasonService")
                    :WaitForChild("RF"):WaitForChild("RequestRankedReward")
            end
            executarComAntiban(function()
                local success, err = pcall(function()
                    remote:InvokeServer(rewardId)
                end)
                if success then
                    UpdateStatus("✅ " .. textoOff .. " coletado!", true)
                else
                    UpdateStatus("❌ Erro: " .. tostring(err), false)
                end
            end)
        end

        local function loopAuto()
            while ativo do
                executarRecompensa()
                waitAntiban(ANTIBAN.INTERVALO_BASE)
            end
        end

        btn.MouseButton1Click:Connect(function()
            ativo = not ativo
            atualizarVisual()
            if ativo then
                task.spawn(loopAuto)
                UpdateStatus("⚡ Auto " .. textoOff .. " ATIVADO!", true)
            else
                UpdateStatus("⏸️ Auto " .. textoOff .. " DESATIVADO!", true)
            end
        end)

        btn.MouseEnter:Connect(function()
            if not ativo then
                TweenService:Create(btn, TweenInfo.new(0.2), {
                    BackgroundColor3 = CORES.PRINCIPAL,
                    BackgroundTransparency = 0.3
                }):Play()
            end
        end)

        btn.MouseLeave:Connect(function()
            if not ativo then
                TweenService:Create(btn, TweenInfo.new(0.2), {
                    BackgroundColor3 = CORES.FUNDO_BOTAO,
                    BackgroundTransparency = 0.5
                }):Play()
            end
        end)

        return btn
    end

    CriarBotaoToggle("🎲 Lucky Spin", "🎲 Lucky Spin [ON]", 55, 1)
    CriarBotaoToggle("💰 Yen", "💰 Yen [ON]", 95, 2)
    CriarBotaoToggle("⚡ Habilidades", "⚡ Habilidades [ON]", 135, 4)

