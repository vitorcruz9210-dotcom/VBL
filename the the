    INTERVALO_BASE = 0.5,             -- Intervalo entre coletas: 0.5 segundos
    VARIACAO_MIN = 0.9,               -- Variação mínima (0.45s)
    VARIACAO_MAX = 1.1,               -- Variação máxima (0.55s)
    ATRASO_PRE_ACAO = {1.0, 1.0},     -- Delay fixo de 1 segundo antes de cada coleta
    CHANCE_PAUSA = 0.10,              -- Reduzida para não interferir no ritmo
    PAUSA_EXTRA = {1.0, 2.0}          -- Pausas extras mais curtas
}

