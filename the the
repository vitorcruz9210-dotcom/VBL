-- ==================== FUNÇÕES AUXILIARES ====================
local function randomFloat(min, max)
    return min + (math.random() * (max - min))
end

local function waitAntiban(baseInterval)
    local variacao = randomFloat(ANTIBAN.VARIACAO_MIN, ANTIBAN.VARIACAO_MAX)
    local tempo = baseInterval * variacao
    task.wait(tempo)
end

local function executarComAntiban(callback)
    -- Atraso fixo de 1 segundo antes da ação
    task.wait(ANTIBAN.ATRASO_PRE_ACAO[1])
    callback()
    if math.random() < ANTIBAN.CHANCE_PAUSA then
        local pausa = randomFloat(ANTIBAN.PAUSA_EXTRA[1], ANTIBAN.PAUSA_EXTRA[2])
        task.wait(pausa)
    end
end

